# ===== 后端配置（server/.env）=====
# 服务端口
PORT=3000

# AI 接口配置（魔搭社区 ModelScope API-Inference，免费）
# 获取 Token：https://modelscope.cn/my/myaccesstoken
AI_API_URL=https://api-inference.modelscope.cn/v1/
AI_API_KEY=your-modelscope-access-token
AI_MODEL=deepseek-ai/DeepSeek-V4-Flash

# 高德 Web 服务 Key（后端调用 POI/天气/地理编码）
# 申请地址：https://lbs.amap.com/
AMAP_SERVER_KEY=your-amap-server-key

# Supabase 服务端配置（后端调用，绕过 RLS，保密）
# 获取地址：https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your-supabase-project-url.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ===== 前端配置（根目录 .env）=====
# 高德 Web 端 JS API Key（前端地图展示）
VITE_AMAP_KEY=your-amap-js-api-key

# 高德 Web 端 JS API 安全密钥（高德新版 JS API 2.0 必填）
VITE_AMAP_SECURITY_CODE=your-amap-security-code

# Supabase 前端配置（anon key，公开，受 RLS 保护）
VITE_SUPABASE_URL=your-supabase-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# 前端 API 地址（开发环境指向本地后端）
VITE_API_BASE_URL=http://localhost:3000
